<Window x:Class="ScadaGUI.AlarmDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alarmi" Height="400" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="lblTag" Grid.Row="0" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

        <DataGrid Grid.Row="1" x:Name="dgAlarms" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                <DataGridTextColumn Header="Granica" Binding="{Binding LimitValue}" Width="70"/>
                <DataGridTextColumn Header="Smjer" Binding="{Binding Direction}" Width="90"/>
                <DataGridTextColumn Header="Poruka" Binding="{Binding Message}" Width="*"/>
                <DataGridTextColumn Header="Stanje" Binding="{Binding State}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,4">
            <Button Content="Acknowledge selektovani" Width="180" Height="28" Margin="0,0,10,0" Click="BtnAck_Click"/>
            <Button Content="Obriši selektovani alarm" Width="180" Height="28" Click="BtnDelete_Click"/>
        </StackPanel>

        <Button Grid.Row="3" Content="Zatvori" Width="90" Height="28"
                HorizontalAlignment="Right" Margin="0,4,0,0" Click="BtnClose_Click"/>
    </Grid>
</Window>
